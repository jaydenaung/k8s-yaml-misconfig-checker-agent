# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

ANTHROPIC_API_KEY=your-key-here

# Optional: override the default AI model
# K8S_CHECKER_MODEL=claude-haiku-4-5-20251001

# ── SIEM Webhook (optional) ───────────────────────────────────────────────────
# POST scan results to a SIEM or alerting endpoint after every completed scan.
#
# WEBHOOK_URL     — endpoint to POST to
# WEBHOOK_TOKEN   — auth token (sent as Bearer <token> or Splunk <token>)
# WEBHOOK_FORMAT  — "json" (default) or "splunk" (Splunk HEC envelope)
#
# Generic JSON (Elastic, Datadog, custom):
# WEBHOOK_URL=https://your-siem.example.com/ingest
# WEBHOOK_TOKEN=your-bearer-token
# WEBHOOK_FORMAT=json
#
# Splunk HEC:
# WEBHOOK_URL=https://splunk.example.com:8088/services/collector
# WEBHOOK_TOKEN=your-splunk-hec-token
# WEBHOOK_FORMAT=splunk
